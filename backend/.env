# HTTP
HTTP_ADDR=:8080
APP_ENV=dev
LOG_LEVEL=debug

# PostgreSQL inside docker compose
DATABASE_URL=postgres://apex:apex@db:5432/apex?sslmode=disable

# PostgreSQL from host machine
LOCAL_DATABASE_URL=postgres://apex:apex@127.0.0.1:5432/apex?sslmode=disable

# Tests
TEST_DATABASE_URL=postgres://apex:apex@127.0.0.1:5433/apex_test?sslmode=disable

# Auth / dev
ACCESS_TOKEN_TTL=24h
OTP_TTL=5m
OTP_DEV_CODE=1111
